{
  "name": "@tafdil/sdk",
  "version": "1.0.0",
  "description": "SDK universel TAFDIL — pont ERP natif ↔ plateforme e-commerce via Supabase",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node18 --outfile=dist/index.js --external:@supabase/supabase-js",
    "build:watch": "npm run build -- --watch",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:unit": "jest --testPathPattern=client",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=integration",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tafdil/erp.git"
  },
  "keywords": ["tafdil", "erp", "sdk", "supabase", "offline", "realtime"],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0"
  }
}
